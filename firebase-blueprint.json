{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information including registration details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "fullName": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number" },
        "registrationDate": { "type": "string", "format": "date-time", "description": "When the user joined" }
      },
      "required": ["uid", "fullName", "email", "phone"]
    },
    "Job": {
      "title": "Job Opportunity",
      "description": "Graduate job opportunities.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "link": { "type": "string" },
        "postedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "company", "link"]
    },
    "Training": {
      "title": "Cooperative Training",
      "description": "Coop training programs for students.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "company": { "type": "string" },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["title", "company", "link"]
    },
    "Discount": {
      "title": "Member Discount",
      "description": "Exclusive discounts for members.",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "discountValue": { "type": "string" },
        "category": { "type": "string" },
        "code": { "type": "string" },
        "logoUrl": { "type": "string" },
        "description": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["storeName", "discountValue"]
    },
    "Course": {
      "title": "Tip or Course",
      "description": "Educational content and tips.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["tip", "course"] },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Collection of graduate jobs."
    },
    "/training/{trainingId}": {
      "schema": "Training",
      "description": "Collection of coop training programs."
    },
    "/discounts/{discountId}": {
      "schema": "Discount",
      "description": "Collection of member discounts."
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Collection of tips and courses."
    }
  }
}
